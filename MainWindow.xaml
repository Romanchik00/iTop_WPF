<Window x:Class="WpfApp1RomRom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1RomRom"
        mc:Ignorable="d"
        Title="main" Height="494" Width="945"
        FontSize="24">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock>Speed:</TextBlock>
                <TextBlock Margin="5,0">0</TextBlock>
                <TextBlock  Margin="0,0,30,0">chars/min</TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock>Fails:</TextBlock>
                <TextBlock Margin="5,0">0</TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock>Difficulty:</TextBlock>
                <TextBlock>15</TextBlock>
                <Slider VerticalAlignment="Center" Value="15"></Slider>
            </StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <CheckBox VerticalAlignment="Center" Margin="0,0,5,0"></CheckBox>
                <TextBlock>Case Sensitive</TextBlock>
            </StackPanel>
            <Button Grid.Row="1" Grid.Column="3">Stop</Button>
            <Button Grid.Row="1" Grid.Column="2">Start</Button>
        </Grid>
        
        <!--adsadsadsadsadsadsa-->
        <Label Grid.Row="1" Background="LightBlue"/>

        <StackPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal">
                <Border Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">`</TextBlock>
                </Border>
                <Border  Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">1</TextBlock>
                </Border>
                <Border Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">2</TextBlock>
                </Border>
                <Border Background="Wheat" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">3</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">4</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">5</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">6</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">7</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">8</TextBlock>
                </Border>
                <Border Background="LightPink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">9</TextBlock>
                </Border>
                <Border Background="Yellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">0</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">-</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">=</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="5,10">Backspace</TextBlock>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">Tab</TextBlock>
                </Border>
                <Border Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">Q</TextBlock>
                </Border>
                <Border Background="Wheat" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">W</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">E</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">R</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">T</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">Y</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">U</TextBlock>
                </Border>
                <Border Background="LightPink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">I</TextBlock>
                </Border>
                <Border Background="Yellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">O</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">P</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">[</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">]</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="36,10">\</TextBlock>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="10,10">CapsLock</TextBlock>
                </Border>
                <Border Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">A</TextBlock>
                </Border>
                <Border Background="Wheat" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">S</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">D</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">F</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">G</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">H</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">J</TextBlock>
                </Border>
                <Border Background="LightPink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">K</TextBlock>
                </Border>
                <Border Background="Yellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">L</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">;</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">'</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="33,10">Enter</TextBlock>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="48,10">Shift</TextBlock>
                </Border>
                <Border Background="Pink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">Z</TextBlock>
                </Border>
                <Border Background="Wheat" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">X</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">C</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">V</TextBlock>
                </Border>
                <Border Background="LightSkyBlue" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">B</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">N</TextBlock>
                </Border>
                <Border Background="Orchid" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">M</TextBlock>
                </Border>
                <Border Background="LightPink" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">,</TextBlock>
                </Border>
                <Border Background="Yellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">.</TextBlock>
                </Border>
                <Border Background="GreenYellow" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="20,10">/</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="48,10">Shift</TextBlock>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Ctr</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Win</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Alt</TextBlock>
                </Border>
                <Border Background="SandyBrown" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="150,10">Space</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Alt</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Win</TextBlock>
                </Border>
                <Border Background="LightGray" Margin="3" BorderBrush="Black" BorderThickness="2" CornerRadius="10">
                    <TextBlock Margin="25,10">Ctr</TextBlock>
                </Border>
            </StackPanel>
        </StackPanel>

    </Grid>

</Window>